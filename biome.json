{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "extends": ["@release/lint/biome"],
  "plugins": [
    {
      "path": "./packages/lint/no-untranslated.grit",
      "includes": [
        "**",
        "!**/playground/**",
        "!**/design/**",
        "!**/boot/**",
        "!**/*.test.*",
        "!**/*.stories.*"
      ]
    }
  ],
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/*.css",
      "!**/*.svg",
      "!apps/frontend/src/app/router.ts"
    ]
  },
  "overrides": [
    {
      "includes": ["packages/translation/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["**/vite.config.ts", "**/vitest.config.ts"],
      "linter": {
        "rules": {
          "style": {
            "noProcessEnv": "off"
          }
        }
      }
    }
  ]
}
