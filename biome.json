{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "plugins": [
    {
      "path": "./no-untranslated.grit",
      "includes": [
        "**",
        "!**/playground/**",
        "!**/design/**",
        "!**/boot/**",
        "!**/*.test.*",
        "!**/*.stories.*"
      ]
    }
  ],
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/*.css",
      "!**/*.svg",
      "!apps/frontend/src/app/router.ts"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noPrivateImports": "error",
        "useExhaustiveDependencies": "error",
        "useJsxKeyInIterable": "error",
        "noNestedComponentDefinitions": "error"
      },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "react-i18next": "Import from @release/translation instead — the app keeps a single i18n surface."
            }
          }
        }
      },
      "suspicious": {
        "noImportCycles": "error",
        "noShadow": "error",
        "useAwait": "error",
        "noFocusedTests": "error",
        "noSkippedTests": "error",
        "noDoubleEquals": "error",
        "noConsole": {
          "level": "error",
          "options": {
            "allow": ["warn", "error"]
          }
        }
      },
      "nursery": {
        "useSortedClasses": "error",
        "noFloatingPromises": "error",
        "noExcessiveSelectorClasses": {
          "level": "on",
          "options": {
            "maxClasses": 3
          }
        },
        "useExhaustiveSwitchCases": "error",
        "noMisusedPromises": "error",
        "useNullishCoalescing": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/translation/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  }
}
